generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id           String   @id @default(cuid())
  code         String   @unique
  fixtureId    Int
  leagueId     Int
  homeTeamId   Int
  awayTeamId   Int
  homeTeamName String
  awayTeamName String
  homeTeamLogo String?
  awayTeamLogo String?
  venue        String?
  matchDate    DateTime
  createdAt    DateTime @default(now())
  players      Player[]

  @@index([fixtureId])
}

model Player {
  id           String   @id @default(cuid())
  roomId       String
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  displayName  String
  sessionToken String   @unique
  isCreator    Boolean  @default(false)
  totalPoints  Int      @default(0)
  captainSlot  Int      @default(0)
  picks        Pick[]
  createdAt    DateTime @default(now())

  @@unique([roomId, displayName])
  @@index([roomId])
  @@index([sessionToken])
}

model Pick {
  id                 String @id @default(cuid())
  playerId           String
  player             Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  footballPlayerId   Int
  footballPlayerName String
  teamId             Int
  position           String
  slotIndex          Int
  points             Int    @default(0)
  pointsBreakdown    Json?

  @@unique([playerId, slotIndex])
  @@index([playerId])
  @@index([footballPlayerId])
}

model MatchCache {
  id          String   @id @default(cuid())
  fixtureId   Int      @unique
  status      String   @default("NS")
  homeScore   Int?
  awayScore   Int?
  minute      Int?
  events      Json?
  playerStats Json?
  updatedAt   DateTime @updatedAt
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String   // page_view, game_created, game_joined, team_saved, share_clicked, help_opened
  page      String?  // URL path e.g. "/", "/room/ABC123", "/room/ABC123/pick"
  metadata  Json?    // Optional extra context
  sessionId String   // Anonymous browser session ID (not tied to a player account)
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
  @@index([sessionId])
}
